# Copy this file to ".env" and fill in your values.

# ---- Supabase database (REQUIRED) ----
# Supabase → Project Settings → Database → Connection string → URI (use the Session pooler one).
DATABASE_URL=postgresql://postgres.xxxx:YOUR-DB-PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

BASE_URL=http://localhost:3000
STORE_NAME=Axero
CURRENCY=inr

# Admin login (local). For production: node make-password.js "yourpassword"
ADMIN_PASSWORD=changeme
# ADMIN_PASSWORD_HASH=
SESSION_SECRET=please-change-this-to-a-long-random-string

# ---- Razorpay (UPI / PhonePe / GPay / cards) — optional; COD works without it ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- Customer site options ----
COD_ENABLED=true
# WhatsApp number with country code, digits only (e.g. 9198XXXXXXXX). Leave blank to hide the button.
WHATSAPP_NUMBER=
SUPPORT_EMAIL=

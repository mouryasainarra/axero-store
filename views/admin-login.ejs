<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Admin login — AXERO</title><link rel="preconnect" href="https://fonts.googleapis.com"><link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet"><link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="login-box">
  <%- include('_logo', { size:'', href:'/' }) %>
  <h2 class="display" style="font-weight:400;letter-spacing:.08em;margin:0 0 4px;">Admin</h2>
  <p class="sub" style="margin-bottom:20px;">Sign in to manage your shop.</p>
  <% if (error) { %><p class="err"><%= error %></p><% } %>
  <form method="POST" action="/admin/login">
    <div class="field" style="text-align:left;margin-bottom:14px;"><label for="password">Password</label><input type="password" id="password" name="password" autofocus required></div>
    <button class="btn btn-primary btn-block" type="submit">Sign in</button>
  </form>
</div>
</body></html>

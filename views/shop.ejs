<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>AXERO — <% if (mode==='sale') { %>Sale<% } else if (mode==='search') { %>Search<% } else { %><%= gender %><% } %> | Style that speaks you</title>
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<% if (payReady) { %><script src="https://checkout.razorpay.com/v1/checkout.js"></script><% } %>
</head>
<body>

<div class="marquee">FREE DELIVERY OVER &#8377;2999 &nbsp;&bull;&nbsp; <b>STYLE THAT SPEAKS YOU</b> &nbsp;&bull;&nbsp; 7-DAY RETURNS</div>

<header class="site"><div class="wrap bar">
  <%- include('_logo', { size:'', href:'/' }) %>
  <nav class="main">
    <% cats.forEach(c => { %>
      <a href="/?gender=<%= gender %>&category=<%= encodeURIComponent(c) %>" class="<%= (mode==='shop' && category === c) ? 'active' : '' %>"><%= c %></a>
    <% }) %>
    <a href="/sale" class="sale-link <%= mode==='sale' ? 'active' : '' %>">Sale</a>
  </nav>
  <div class="tools">
    <button class="icbtn" id="searchBtn" aria-label="Search"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg></button>
    <span class="gender-switch">
      <a href="/?gender=Men" class="<%= gender === 'Men' && mode!=='sale' ? 'on' : '' %>">Men</a>
      <a href="/?gender=Women" class="<%= gender === 'Women' && mode!=='sale' ? 'on' : '' %>">Women</a>
    </span>
    <button class="icbtn" id="wishBtn" aria-label="Wishlist"><svg viewBox="0 0 24 24"><path d="M12 20s-7-4.3-9.3-8.5C1 8 2.5 5 5.5 5c1.9 0 3.1 1 2.5 1 .6 0 1.8-1 3.5-1 3 0 4.5 3 2.8 6.5C19 15.7 12 20 12 20Z"/></svg><span class="badge" id="wishCount">0</span></button>
    <button class="icbtn" id="bagBtn" aria-label="Open bag">
      <svg viewBox="0 0 24 24"><path d="M6 8h12l-1 12H7L6 8Z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/></svg>
      <span class="badge" id="bagCount">0</span>
    </button>
  </div>
</div>
<div class="searchbar" id="searchBar">
  <form class="wrap" action="/" method="get">
    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
    <input type="search" name="q" value="<%= typeof q !== 'undefined' ? q : '' %>" placeholder="Search for suits, tees, dresses…" autocomplete="off">
    <button class="btn btn-primary" type="submit">Search</button>
  </form>
</div>
</header>

<% if (mode === 'shop') { %>
<section class="hero"><div class="wrap">
  <img class="hero-logo" src="/logo.png" alt="AXERO">
  <p class="eyebrow"><%= gender %> &mdash; <%= cats.join(' • ') %></p>
  <p class="tagline">Style that speaks you</p>
  <div><a href="#shop" class="btn btn-primary">Shop <%= gender %></a></div>
</div></section>
<% } %>

<main class="wrap" id="shop">
  <% if (mode === 'search') { %>
    <div class="section-head"><h2>Search results</h2><span class="count"><%= products.length %> found for &ldquo;<%= q %>&rdquo;</span></div>
  <% } else if (mode === 'sale') { %>
    <div class="section-head"><h2>Sale</h2><span class="count"><%= products.length %> reduced styles</span></div>
  <% } else { %>
    <p class="breadcrumb">Home / <a href="/?gender=<%= gender %>" style="color:var(--cream);"><%= gender %></a> / <b><%= category === 'All' ? 'All' : category %></b></p>
    <div class="section-head"><h2><%= category === 'All' ? gender + '\u2019s Collection' : category %></h2><span class="count"><%= products.length %> styles</span></div>
    <div class="chips">
      <a href="/?gender=<%= gender %>" class="chip <%= category === 'All' ? 'active' : '' %>">All</a>
      <% cats.forEach(c => { %>
        <a href="/?gender=<%= gender %>&category=<%= encodeURIComponent(c) %>" class="chip <%= category === c ? 'active' : '' %>"><%= c %></a>
      <% }) %>
    </div>
  <% } %>

  <% if (products.length) { %>
  <div class="toolbar">
    <span class="muted-sm"><%= products.length %> item<%= products.length===1?'':'s' %></span>
    <label class="sortwrap">Sort
      <select id="sortSel" data-base="<%= mode==='sale' ? '/sale' : '/' %>" data-gender="<%= gender %>" data-cat="<%= typeof category!=='undefined'?category:'All' %>" data-q="<%= typeof q!=='undefined'?q:'' %>" data-mode="<%= mode %>">
        <option value="" <%= !sort ? 'selected':'' %>>Newest</option>
        <option value="price-asc" <%= sort==='price-asc'?'selected':'' %>>Price: Low to High</option>
        <option value="price-desc" <%= sort==='price-desc'?'selected':'' %>>Price: High to Low</option>
        <option value="name" <%= sort==='name'?'selected':'' %>>Name A–Z</option>
      </select>
    </label>
  </div>
  <% } %>

  <div class="grid">
    <% if (!products.length) { %>
      <div class="empty"><b>Nothing here yet</b><% if (mode==='search') { %>Try a different word.<% } else { %>Add products from the admin panel and they&rsquo;ll appear here.<% } %></div>
    <% } %>
    <% products.forEach(p => {
        const sizes = (p.sizes || '').split(',').map(s => s.trim()).filter(Boolean);
        const off = p.compare_at ? Math.round((1 - p.price / p.compare_at) * 100) : 0;
        const soldOut = p.stock <= 0;
        const r = p.rating;
    %>
      <article class="card">
        <button class="heart" data-wish data-id="<%= p.id %>" data-name="<%= p.name.replace(/"/g,'&quot;') %>" data-price="<%= p.price %>" data-img="<%= p.image_url %>" aria-label="Save to wishlist">
          <svg viewBox="0 0 24 24"><path d="M12 20s-7-4.3-9.3-8.5C1 8 2.5 5 5.5 5c1.9 0 3.1 1 2.5 1 .6 0 1.8-1 3.5-1 3 0 4.5 3 2.8 6.5C19 15.7 12 20 12 20Z"/></svg>
        </button>
        <a class="ph" href="/product/<%= p.id %>">
          <% if (p.image_url) { %><img src="<%= p.image_url %>" alt="<%= p.name %>" loading="lazy"><% } else { %><div class="noimg"><%= p.category %></div><% } %>
          <% if (p.compare_at) { %><span class="ribbon">-<%= off %>%</span><% } %>
          <% if (soldOut) { %><div class="soldout">Sold out</div><% } %>
        </a>
        <div class="info">
          <a class="name" href="/product/<%= p.id %>"><%= p.name %></a>
          <% if (r) { %><p class="stars"><%- '★'.repeat(Math.round(r.avg)) %><span class="dim"><%- '★'.repeat(5-Math.round(r.avg)) %></span> <small>(<%= r.count %>)</small></p><% } %>
          <p class="meta"><%= p.category %><% if (sizes.length) { %> &bull; <%= sizes.join(' / ') %><% } %></p>
          <div class="price"><b><%= money(p.price) %></b><% if (p.compare_at) { %><span class="was"><%= money(p.compare_at) %></span><% } %></div>
          <% if (!soldOut) { %>
          <div class="row">
            <select aria-label="Size for <%= p.name %>" id="size-<%= p.id %>"><% sizes.forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %></select>
            <button class="add" data-id="<%= p.id %>" data-name="<%= p.name.replace(/"/g,'&quot;') %>" data-price="<%= p.price %>" data-img="<%= p.image_url %>" data-size-select="size-<%= p.id %>">Add to bag</button>
          </div>
          <% } else { %><a class="btn btn-ghost btn-block" href="/product/<%= p.id %>">View</a><% } %>
        </div>
      </article>
    <% }) %>
  </div>
</main>

<%- include('_footer') %>
<%- include('_drawer') %>

<script>window.AXERO_PAY_READY = <%= payReady ? 'true' : 'false' %>; window.AXERO_COD = <%= COD_ENABLED ? 'true':'false' %>;</script>
<script src="/js/cart.js"></script>
</body>
</html>
